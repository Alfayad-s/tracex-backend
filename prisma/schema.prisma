generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String               @id @default(uuid())
  email                String               @unique @db.VarChar(255)
  passwordHash         String               @map("password_hash") @db.VarChar(255)
  name                 String?              @db.VarChar(255)
  currency             String?              @db.VarChar(10)
  webhookUrl           String?              @map("webhook_url") @db.VarChar(500)
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  expenses             Expense[]
  categories           Category[]
  budgets              Budget[]
  recurringExpenses    RecurringExpense[]
  categoryPreferences  CategoryPreference[]

  @@map("users")
}

model Category {
  id           String                @id @default(uuid())
  name         String                @db.VarChar(100)
  userId       String?               @map("user_id")
  user         User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  color        String?               @db.VarChar(20)
  icon         String?               @db.VarChar(50)
  deletedAt    DateTime?             @map("deleted_at")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  preferences  CategoryPreference[]
  expenses     Expense[]

  @@map("categories")
}

model CategoryPreference {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  color      String?  @db.VarChar(20)
  icon       String?  @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([userId, categoryId])
  @@map("category_preferences")
}

model Expense {
  id          String    @id @default(uuid())
  date        DateTime  @db.Date
  amount      Decimal   @db.Decimal(12, 2)
  category    String    @db.VarChar(100)
  categoryId  String?   @map("category_id")
  categoryRef Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  description String?   @db.Text
  receiptUrl  String?   @map("receipt_url") @db.VarChar(500)
  currency    String?   @db.VarChar(10)
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("expenses")
}

model Budget {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String   @db.VarChar(100)
  year      Int
  month     Int
  limit     Decimal  @db.Decimal(12, 2)
  shareSlug String?  @unique @map("share_slug") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, category, year, month])
  @@map("budgets")
}

model RecurringExpense {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    String   @db.VarChar(100)
  amount      Decimal  @db.Decimal(12, 2)
  description String?  @db.Text
  frequency   String   @db.VarChar(20)
  startDate   DateTime @map("start_date") @db.Date
  nextRunAt   DateTime @map("next_run_at") @db.Date
  lastRunAt   DateTime? @map("last_run_at") @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("recurring_expenses")
}
