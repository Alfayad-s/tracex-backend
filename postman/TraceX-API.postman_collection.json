{
  "info": {
    "name": "TraceX Expense API",
    "description": "TraceX backend API for expense tracking. Set `baseUrl` and `token` in your environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "expenseId", "value": "" },
    { "key": "categoryId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign up",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/signup"
          }
        },
        {
          "name": "Sign in",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data && json.data.access_token) {",
                  "  pm.collectionVariables.set('token', json.data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/signin"
          }
        },
        {
          "name": "Me (current user)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/categories"
          }
        },
        {
          "name": "Get category by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/categories/{{categoryId}}"
          }
        },
        {
          "name": "Create category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Subscriptions\",\n  \"color\": \"#8b5cf6\",\n  \"icon\": \"credit-card\"\n}"
            },
            "url": "{{baseUrl}}/api/categories"
          }
        },
        {
          "name": "Update category",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated name\",\n  \"color\": \"#000000\"\n}"
            },
            "url": "{{baseUrl}}/api/categories/{{categoryId}}"
          }
        },
        {
          "name": "Delete category",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/categories/{{categoryId}}"
          }
        }
      ]
    },
    {
      "name": "Expenses",
      "item": [
        {
          "name": "List expenses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/expenses?page=1&limit=20&sort=date&order=desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "expenses"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "from", "value": "", "disabled": true },
                { "key": "to", "value": "", "disabled": true },
                { "key": "category", "value": "", "disabled": true },
                { "key": "sort", "value": "date" },
                { "key": "order", "value": "desc" }
              ]
            }
          }
        },
        {
          "name": "Get expense by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/expenses/{{expenseId}}"
          }
        },
        {
          "name": "Create expense",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data && json.data.id) {",
                  "  pm.collectionVariables.set('expenseId', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2025-02-21\",\n  \"amount\": 29.99,\n  \"category\": \"Food\",\n  \"description\": \"Lunch at cafe\"\n}"
            },
            "url": "{{baseUrl}}/api/expenses"
          }
        },
        {
          "name": "Bulk create expenses",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expenses\": [\n    { \"date\": \"2025-02-20\", \"amount\": 15, \"category\": \"Food\", \"description\": \"Breakfast\" },\n    { \"date\": \"2025-02-21\", \"amount\": 50, \"category\": \"Transport\" }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/expenses/bulk"
          }
        },
        {
          "name": "Update expense",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 35,\n  \"description\": \"Updated description\"\n}"
            },
            "url": "{{baseUrl}}/api/expenses/{{expenseId}}"
          }
        },
        {
          "name": "Restore expense",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/expenses/{{expenseId}}/restore"
          }
        },
        {
          "name": "Delete expense (soft)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/expenses/{{expenseId}}"
          }
        }
      ]
    },
    {
      "name": "Summary & Export",
      "item": [
        {
          "name": "Summary by period",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/expenses/summary?from=2025-02-01&to=2025-02-28&groupBy=month",
              "host": ["{{baseUrl}}"],
              "path": ["api", "expenses", "summary"],
              "query": [
                { "key": "from", "value": "2025-02-01" },
                { "key": "to", "value": "2025-02-28" },
                { "key": "groupBy", "value": "month" }
              ]
            }
          }
        },
        {
          "name": "Summary by category",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/expenses/summary/by-category?from=2025-02-01&to=2025-02-28",
              "host": ["{{baseUrl}}"],
              "path": ["api", "expenses", "summary", "by-category"],
              "query": [
                { "key": "from", "value": "2025-02-01" },
                { "key": "to", "value": "2025-02-28" }
              ]
            }
          }
        },
        {
          "name": "Export CSV",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/expenses/export?format=csv&from=2025-02-01&to=2025-02-28",
              "host": ["{{baseUrl}}"],
              "path": ["api", "expenses", "export"],
              "query": [
                { "key": "format", "value": "csv" },
                { "key": "from", "value": "2025-02-01" },
                { "key": "to", "value": "2025-02-28" }
              ]
            }
          }
        }
      ]
    }
  ]
}
