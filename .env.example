# Copy to .env and fill in values
# Database (e.g. Supabase PostgreSQL: Project Settings → Database → Connection string URI)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Auth: secret used to sign JWTs (use a long random string in production)
JWT_SECRET="your-secret-at-least-32-chars-long"

# Optional: server port (default 3000)
PORT=3000
