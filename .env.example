# Copy to .env and fill in values. Never commit .env.

# Supabase: POOLER for app (port 6543). Project Settings → Database → Connection pooling → URI.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# Direct DB URL for Prisma migrations (avoids migrate hanging behind pooler).
# Supabase: use DIRECT (port 5432). Project Settings → Database → Connection string → URI.
# Add ?connect_timeout=15 so connection fails fast if unreachable.
# Local/Docker: set to same as DATABASE_URL (e.g. postgresql://user:pass@localhost:5432/tracex).
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?connect_timeout=15"

# JWT signing secret (use a long random string in production)
JWT_SECRET="your-secret-at-least-32-chars"

# Server
PORT=3000
NODE_ENV=development

# Log level: trace, debug, info, warn, error
LOG_LEVEL=info

# CORS allowed origin (comma-separated; * for all in dev)
CORS_ORIGIN="*"
