# Copy to .env and fill in values. Never commit .env.

# Supabase: use POOLER (port 6543). Project Settings → Database → Connection pooling → URI.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# JWT signing secret (use a long random string in production)
JWT_SECRET="your-secret-at-least-32-chars"

# Server
PORT=3000
NODE_ENV=development

# Log level: trace, debug, info, warn, error
LOG_LEVEL=info

# CORS allowed origin (comma-separated; * for all in dev)
CORS_ORIGIN="*"
